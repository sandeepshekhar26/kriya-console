{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kriya Console",
  "version": "0.2.4",
  "identifier": "id.kriya.console",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kriya Console",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "On-device governance control-plane for AI agents",
    "longDescription": "Kriya Console — the on-device control plane for governed AI agents. Auto-discovers and tails the on-device signed-audit trail, walks the gateway setup (permissions + MCP client wiring), and turns the verified trail into compliance evidence. Paid features are gated by an offline license; nothing leaves the machine.",
    "externalBin": [
      "binaries/kriya-gateway",
      "binaries/kriya-hook",
      "binaries/kriya-hermes-hook"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  }
}
