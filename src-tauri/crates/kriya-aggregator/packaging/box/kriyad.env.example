# kriyad configuration — this is the ENTIRE config surface (4 variables). Copy to
# /etc/kriyad/kriyad.env and edit. No other config file, no flags, no env beyond these.

# Address to bind the HTTPS (mTLS) listener on.
KRIYAD_BIND=0.0.0.0:8443

# The append-only SQLite store. Under systemd StateDirectory=kriyad this is /var/lib/kriyad.
KRIYAD_DB=/var/lib/kriyad/kriyad.sqlite

# The offline `control-plane` license. kriyad refuses to start ingest without a valid one
# (verified on-device against the pinned issuer key — no phone-home).
KRIYAD_LICENSE=/etc/kriyad/kriyad-license.json

# Directory holding the mTLS material: server.pem + server.key + the pinned client CA (ca.pem).
# Bootstrap a dev CA with kriyd-ca.sh, or drop your own CA here. If this directory is
# absent, kriyad serves plain HTTP (dev only — never expose an un-pinned listener).
KRIYAD_CA_DIR=/etc/kriyad/ca
