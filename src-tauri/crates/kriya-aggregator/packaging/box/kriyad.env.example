# kriyad configuration — the whole config surface is 5 variables; this file sets 2 of them.
# Copy to /etc/kriyad/kriyad.env and edit. No other config file, no flags.
#
# KRIYAD_LICENSE and KRIYAD_CA_DIR are NOT set here on purpose: under the hardened systemd
# unit they are supplied via systemd credentials (LoadCredential= in kriyad.service), because
# the sandboxed DynamicUser cannot read root-owned /etc/kriyad directly (systemd reads the
# files as root and passes read-only copies to the service). You still just drop the files at
# /etc/kriyad/kriyad-license.json and /etc/kriyad/ca/ — the unit wires them through.
# (EnvironmentFile overrides Environment=, so setting them here would defeat that wiring.
# Only set them for a non-systemd / manual run, e.g. `kriyad ingest-file`.)

# Address to bind the HTTPS (mTLS) listener on.
KRIYAD_BIND=0.0.0.0:8443

# The append-only SQLite store. Under systemd StateDirectory=kriyad this is /var/lib/kriyad.
KRIYAD_DB=/var/lib/kriyad/kriyad.sqlite

# P6 cert-role migration grace (default OFF — the shipped posture enforces cert roles). Set to 1 ONLY
# during the reissue window to keep pre-P6 role-less certs working; unset it once every peer presents a
# role-stamped cert. See the aggregator INSTALL.md §CERTS for the migration path.
# KRIYAD_ALLOW_LEGACY_CERTS=1
