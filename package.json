{
  "name": "kriya-console",
  "version": "0.2.1",
  "private": true,
  "description": "kriya Console — governed-agent oversight (proprietary, paid tier): cross-app signed-audit viewer, policy editor, approval routing, budget controls.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:clean-build": "vitest run no-sample-in-build",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "release:bump": "bash scripts/bump-version.sh",
    "capture": "node demo/capture/capture-shots.mjs",
    "demo:approvals": "node --experimental-strip-types demo/approvals-demo.mts",
    "demo:compliance": "node --experimental-strip-types demo/compliance-demo.mts",
    "gen:au-sample": "node --experimental-strip-types scripts/gen-au-sample.mts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@tauri-apps/api": "^2.11.1",
    "@types/js-yaml": "^4.0.9",
    "js-yaml": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
